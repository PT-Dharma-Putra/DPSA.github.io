---
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import Footer from "../../../components/Footer.astro";

export function getStaticPaths() {
  const roles = [
    {
      slug: "it",
      title: "IT Internship",
      fullTitle: "Internship Information Technology (IT)",
      qualifications: [
        "Bachelor’s degree or active student in Information Technology, Computer Science, or related fields",
        "Basic understanding of web development (HTML, CSS, JavaScript)",
        "Knowledge of hardware and software troubleshooting",
        "Fast learner and tech-savvy",
        "Detail-oriented and disciplined",
        "Ability to work in a team and communicate effectively",
      ],
    },
    {
      slug: "marketing",
      title: "Marketing Internship",
      fullTitle: "Internship Marketing & Creative",
      qualifications: [
        "Bachelor’s degree or active student in Marketing, Communications, or related fields",
        "Familiarity with social media trends and platforms",
        "Creative thinking and ability to contribute new ideas",
        "Good writing and communication skills",
        "Basic understanding of branding and digital marketing",
        "Active and energetic personality",
      ],
    },
    {
      slug: "finance",
      title: "Finance Internship",
      fullTitle: "Internship Finance & Accounting",
      qualifications: [
        "Bachelor’s degree or active student in Accounting, Finance, or related fields",
        "Proficiency in Microsoft Excel is a must",
        "Strong attention to detail and accuracy",
        "Basic understanding of financial reports and administration",
        "Disciplined and honest",
        "Able to work with deadlines",
      ],
    },
    {
      slug: "maintenance",
      title: "Maintenance Internship",
      fullTitle: "Internship Maintenance & Technical",
      qualifications: [
        "Bachelor’s degree or active student in Mechanical/Electrical Engineering or related fields",
        "Basic knowledge of machine maintenance and troubleshooting",
        "Willingness to learn and work in a production environment",
        "Strong problem-solving skills",
        "Disciplined and follows safety regulations",
        "Good physical stamina",
      ],
    },
    {
      slug: "operational",
      title: "Operational Internship",
      fullTitle: "Internship Operational",
      qualifications: [
        "Bachelor’s degree or active student in Operations Management, Engineering, Business Administration, or related fields",
        "Good organizational and coordination skills",
        "Basic understanding of operational workflows and project coordination",
        "Detail-oriented, disciplined, and able to work under deadlines",
        "Willing to learn and adaptable in a dynamic environment",
        "Fresh graduates and students are welcome to apply",
      ],
    },
    {
      slug: "production",
      title: "Production Internship",
      fullTitle: "Internship Production",
      qualifications: [
        "Bachelor’s degree or active student in Industrial Engineering, Wood Technology, or related technical fields",
        "Interest in mass production and CNC technology",
        "Understanding of production workflows and quality control basics",
        "Disciplined, hardworking, and detail-oriented",
        "Willing to work on the production floor when needed",
        "Fresh graduates and students are welcome to apply",
      ],
    },
  ];

  return roles.map((role) => ({
    params: { slug: role.slug },
    props: { role },
  }));
}

const { role } = Astro.props;
---

<Layout title={`${role.title} | Dharma Putra Sejahtera Abadi`}>
  <Navbar />

  <main class="pt-32 pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <!-- Breadcrumb -->
      <nav class="mb-12">
        <ol
          class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest"
        >
          <li>
            <a
              href="/careers"
              class="text-slate-400 hover:text-primary transition-colors"
              >Careers</a
            >
          </li>
          <li class="text-slate-300">/</li>
          <li>
            <a
              href="/careers/internships"
              class="text-slate-400 hover:text-primary transition-colors"
              >Internships</a
            >
          </li>
          <li class="text-slate-300">/</li>
          <li class="text-primary">{role.title}</li>
        </ol>
      </nav>

      <div
        class="bg-white border border-zinc-100 rounded-3xl p-8 md:p-16 shadow-sm"
      >
        <header class="mb-12">
          <h1
            class="font-display text-4xl md:text-5xl font-bold text-secondary uppercase italic mb-4"
          >
            {role.fullTitle}
          </h1>
          <div class="h-1 w-20 bg-primary mb-8"></div>
        </header>

        <section class="mb-16">
          <h2
            class="font-display text-xl font-bold text-secondary uppercase tracking-widest mb-8 border-b border-zinc-100 pb-4"
          >
            Qualifications
          </h2>
          <ul class="space-y-6">
            {
              role.qualifications.map((qual) => (
                <li class="flex items-start gap-4 text-slate-600 leading-relaxed">
                  <span class="material-icons-outlined text-primary mt-1">
                    check_circle
                  </span>
                  <span>{qual}</span>
                </li>
              ))
            }
          </ul>
        </section>

        <section
          class="bg-zinc-50 rounded-2xl p-8 md:p-10 border border-zinc-100"
        >
          <h2
            class="font-display text-xl font-bold text-secondary uppercase tracking-widest mb-6"
          >
            How to Apply
          </h2>
          <p class="text-slate-600 mb-8 leading-relaxed">
            Interested in joining our team? Please send your application via
            email with the following details:
          </p>

          <div class="space-y-6">
            <div class="flex items-center gap-4">
              <div
                class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-primary shadow-sm"
              >
                <span class="material-icons-outlined">email</span>
              </div>
              <div>
                <span
                  class="text-xs text-slate-400 uppercase font-bold tracking-widest block mb-1"
                  >Send to</span
                >
                <a
                  href="mailto:hrga@dharmaputrainterior.co.id"
                  class="text-secondary font-bold hover:text-primary transition-colors"
                >
                  hrga@dharmaputrainterior.co.id
                </a>
              </div>
            </div>

            <div class="flex items-center gap-4">
              <div
                class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-primary shadow-sm"
              >
                <span class="material-icons-outlined">attachment</span>
              </div>
              <div>
                <span
                  class="text-xs text-slate-400 uppercase font-bold tracking-widest block mb-1"
                  >Include Assets</span
                >
                <span class="text-secondary font-bold"
                  >Please send your CV and portfolio (if available)</span
                >
              </div>
            </div>
          </div>

          <div class="mt-12 pt-8 border-t border-zinc-200/50">
            <a
              href={`mailto:hrga@dharmaputrainterior.co.id?subject=Internship Application - ${role.title}`}
              class="inline-flex items-center justify-center gap-3 bg-secondary text-white px-10 py-5 rounded-sm font-bold hover:bg-primary transition-all tracking-widest text-xs uppercase w-full sm:w-auto"
            >
              Send Application Email
              <span class="material-icons-outlined">send</span>
            </a>
          </div>
        </section>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
