---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

const internshipRoles = [
  {
    title: "Internship Information Technology (IT)",
    slug: "it",
    icon: "code",
    qualifications: [
      "Bachelor’s degree or active student in Information Technology, Computer Science, or related fields",
      "Basic understanding of web development (HTML, CSS, JavaScript)",
      "Knowledge of hardware and software troubleshooting",
      "Fast learner and tech-savvy",
      "Detail-oriented and disciplined",
      "Ability to work in a team and communicate effectively",
    ],
  },
  {
    title: "Internship Marketing & Creative",
    slug: "marketing",
    icon: "campaign",
    qualifications: [
      "Bachelor’s degree or active student in Marketing, Communications, or related fields",
      "Familiarity with social media trends and platforms",
      "Creative thinking and ability to contribute new ideas",
      "Good writing and communication skills",
      "Basic understanding of branding and digital marketing",
      "Active and energetic personality",
    ],
  },
  {
    title: "Internship Finance & Accounting",
    slug: "finance",
    icon: "payments",
    qualifications: [
      "Bachelor’s degree or active student in Accounting, Finance, or related fields",
      "Proficiency in Microsoft Excel is a must",
      "Strong attention to detail and accuracy",
      "Basic understanding of financial reports and administration",
      "Disciplined and honest",
      "Able to work with deadlines",
    ],
  },
  {
    title: "Internship Maintenance & Technical",
    slug: "maintenance",
    icon: "settings_suggest",
    qualifications: [
      "Bachelor’s degree or active student in Mechanical/Electrical Engineering or related fields",
      "Basic knowledge of machine maintenance and troubleshooting",
      "Willingness to learn and work in a production environment",
      "Strong problem-solving skills",
      "Disciplined and follows safety regulations",
      "Good physical stamina",
    ],
  },
  {
    title: "Internship Operational",
    slug: "operational",
    icon: "rebase_edit",
    qualifications: [
      "Bachelor’s degree or active student in Operations Management, Engineering, Business Administration, or related fields",
      "Good organizational and coordination skills",
      "Basic understanding of operational workflows and project coordination",
      "Detail-oriented, disciplined, and able to work under deadlines",
      "Willing to learn and adaptable in a dynamic environment",
      "Fresh graduates and students are welcome to apply",
    ],
  },
  {
    title: "Internship Production",
    slug: "production",
    icon: "precision_manufacturing",
    qualifications: [
      "Bachelor’s degree or active student in Industrial Engineering, Wood Technology, or related technical fields",
      "Interest in mass production and CNC technology",
      "Understanding of production workflows and quality control basics",
      "Disciplined, hardworking, and detail-oriented",
      "Willing to work on the production floor when needed",
      "Fresh graduates and students are welcome to apply",
    ],
  },
];
---

<Layout title="Internship Programs | Dharma Putra Sejahtera Abadi">
  <Navbar isSolid={true} />

  <main class="pt-24 pb-24">
    <div class="max-w-6xl mx-auto px-6">
      <!-- Header -->
      <header class="mb-20 text-center max-w-4xl mx-auto">
        <a
          href="/careers"
          class="text-primary font-bold text-xs uppercase tracking-[0.2em] flex items-center justify-center gap-2 mb-8 hover:opacity-70 transition-opacity"
        >
          <span class="material-icons-outlined text-sm">arrow_back</span>
          Back to Careers
        </a>
        <h1
          class="font-display text-4xl md:text-6xl font-bold text-secondary mb-6 leading-tight italic uppercase"
        >
          INTERNSHIP <span class="not-italic text-primary">PROGRAMS</span>
        </h1>
        <p class="text-slate-500 text-lg leading-relaxed">
          Unlock your potential and gain industry-leading experience with our
          specialized internship tracks. We provide hands-on mentorship across
          various departments to jumpstart your career.
        </p>
      </header>

      <!-- Roles Grid / Carousel -->
      <div class="embla relative group" id="internship-carousel">
        <div
          class="embla__container grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12 md:mb-24"
        >
          {
            internshipRoles.map((role) => (
              <div class="embla__slide min-w-0 flex-[0_0_100%] md:flex-none px-4 md:px-0">
                <div class="bg-white border border-zinc-100 rounded-3xl p-8 md:p-12 shadow-sm hover:shadow-xl transition-shadow duration-500 flex flex-col h-full">
                  <div class="flex items-center gap-6 mb-8 pb-6 border-b border-zinc-50">
                    <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center text-primary">
                      <span class="material-icons-outlined text-3xl">
                        {role.icon}
                      </span>
                    </div>
                    <h2 class="font-display text-2xl font-bold text-secondary uppercase leading-tight">
                      {role.title}
                    </h2>
                  </div>

                  <div class="flex-grow">
                    <h3 class="text-xs font-bold text-primary uppercase tracking-widest mb-6">
                      Qualifications
                    </h3>
                    <ul class="space-y-4 mb-10">
                      {role.qualifications.map((qual) => (
                        <li class="flex items-start gap-3 text-slate-600 text-sm leading-relaxed">
                          <span class="material-icons-outlined text-accent-orange text-[1.2rem] mt-0.5">
                            check_circle
                          </span>
                          <span class="text-accent-orange/80">{qual}</span>
                        </li>
                      ))}
                    </ul>
                  </div>

                  <div class="pt-8 border-t border-zinc-50">
                    <a
                      href={`mailto:hrga@dharmaputrainterior.co.id?subject=Internship Application - ${role.title}`}
                      class="inline-flex items-center justify-center gap-3 bg-secondary text-white w-full py-4 rounded-sm font-bold hover:bg-primary transition-all tracking-widest text-[10px] uppercase"
                    >
                      Apply for this position
                      <span class="material-icons-outlined text-sm">email</span>
                    </a>
                  </div>
                </div>
              </div>
            ))
          }
        </div>

        <!-- Mobile Navigation Controls -->
        <div class="md:hidden">
          <!-- Prev Button -->
          <button
            class="absolute top-1/2 left-0 -translate-y-1/2 -translate-x-1/2 z-10 w-12 h-12 rounded-full bg-white shadow-lg border border-zinc-100 flex items-center justify-center text-primary hover:bg-primary hover:text-white transition-all duration-300 opacity-0 group-hover:opacity-100 pointer-events-auto"
            id="intern-prev"
            aria-label="Previous slide"
          >
            <span class="material-icons-outlined">chevron_left</span>
          </button>

          <!-- Next Button -->
          <button
            class="absolute top-1/2 right-0 -translate-y-1/2 translate-x-1/2 z-10 w-12 h-12 rounded-full bg-white shadow-lg border border-zinc-100 flex items-center justify-center text-primary hover:bg-primary hover:text-white transition-all duration-300 opacity-0 group-hover:opacity-100 pointer-events-auto"
            id="intern-next"
            aria-label="Next slide"
          >
            <span class="material-icons-outlined">chevron_right</span>
          </button>

          <!-- Dots -->
          <div class="flex justify-center gap-2 mt-4" id="intern-dots"></div>
        </div>
      </div>

      <!-- Application Info -->
      <section
        class="bg-secondary rounded-[3rem] p-10 md:p-20 text-white relative overflow-hidden text-center"
      >
        <div
          class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-bl-full -mr-32 -mt-32"
        >
        </div>
        <div
          class="absolute bottom-0 left-0 w-64 h-64 bg-primary/10 rounded-tr-full -ml-32 -mb-32"
        >
        </div>

        <div class="relative z-10 max-w-2xl mx-auto">
          <h2
            class="font-display text-3xl md:text-5xl font-bold mb-8 uppercase italic"
          >
            READY TO <span class="not-italic text-primary">APPLY?</span>
          </h2>
          <p class="text-slate-300 mb-12 text-lg">
            Please send your updated CV and portfolio (if available) to our
            recruitment team. Make sure to specify the position you are applying
            for in the email subject.
          </p>

          <div
            class="flex flex-col md:flex-row items-center justify-center gap-8 mb-12"
          >
            <div class="flex flex-col items-center">
              <span
                class="text-xs text-primary font-bold uppercase tracking-widest mb-2"
                >Apply via Email</span
              >
              <a
                href="mailto:hrga@dharmaputrainterior.co.id"
                class="text-xl md:text-2xl font-bold hover:text-primary transition-colors"
              >
                hrga@dharmaputrainterior.co.id
              </a>
            </div>
          </div>

          <a
            href="mailto:hrga@dharmaputrainterior.co.id?subject=Internship Application - [Position Name]"
            class="inline-flex items-center gap-4 bg-primary text-white px-10 py-5 rounded-sm font-bold hover:bg-white hover:text-secondary transition-all tracking-[0.2em] text-sm uppercase"
          >
            Send Application Email
            <span class="material-icons-outlined">send</span>
          </a>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  import EmblaCarousel from "embla-carousel";

  const setupCarousel = () => {
    const emblaNode = document.querySelector(
      "#internship-carousel",
    ) as HTMLElement;
    const viewportNode = emblaNode?.querySelector(
      ".embla__container",
    ) as HTMLElement;
    const dotsNode = document.querySelector("#intern-dots") as HTMLElement;
    const prevBtn = document.querySelector("#intern-prev") as HTMLElement;
    const nextBtn = document.querySelector("#intern-next") as HTMLElement;

    if (!emblaNode || !viewportNode) return;

    // Only activate Embla on small screens
    const isMobile = () => window.innerWidth < 1024; // Use 1024 to match lg:grid-cols-2

    let emblaApi: any;

    const initEmbla = () => {
      if (isMobile() && !emblaApi) {
        // Initialize Embla
        // Remove grid classes for carousel mode
        viewportNode.classList.remove(
          "grid",
          "grid-cols-1",
          "lg:grid-cols-2",
          "gap-8",
        );
        viewportNode.classList.add("flex");

        emblaApi = EmblaCarousel(emblaNode, { loop: true, align: "center" });

        // Generate dots
        if (dotsNode) {
          const slides = emblaApi.scrollSnapList();
          dotsNode.innerHTML = slides
            .map(
              () =>
                `<button class="w-2 h-2 rounded-full bg-primary/20 transition-all duration-300"></button>`,
            )
            .join("");

          const dots = Array.from(dotsNode.children) as HTMLElement[];

          const updateDots = () => {
            const selected = emblaApi.selectedScrollSnap();
            dots.forEach((dot, i) => {
              if (i === selected) {
                dot.classList.add("w-6", "bg-primary");
                dot.classList.remove("bg-primary/20");
              } else {
                dot.classList.remove("w-6", "bg-primary");
                dot.classList.add("bg-primary/20");
              }
            });
          };

          emblaApi.on("select", updateDots);
          emblaApi.on("init", updateDots);
          updateDots();

          dots.forEach((dot, i) => {
            dot.addEventListener("click", () => emblaApi.scrollTo(i));
          });
        }

        // Button listeners
        if (prevBtn) prevBtn.onclick = () => emblaApi.scrollPrev();
        if (nextBtn) nextBtn.onclick = () => emblaApi.scrollNext();
      } else if (!isMobile()) {
        if (emblaApi) {
          emblaApi.destroy();
          emblaApi = null;
        }
        // Restore grid layout
        viewportNode.classList.add(
          "grid",
          "grid-cols-1",
          "lg:grid-cols-2",
          "gap-8",
        );
        viewportNode.classList.remove("flex");

        if (dotsNode) dotsNode.innerHTML = "";
      }
    };

    initEmbla();
    window.addEventListener("resize", initEmbla);
  };

  document.addEventListener("DOMContentLoaded", setupCarousel);
  document.addEventListener("astro:page-load", setupCarousel);
</script>
