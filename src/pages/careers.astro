---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Careers | Dharma Putra Sejahtera Abadi">
  <Navbar isSolid={true} />

  <main class="pt-24 pb-24">
    <div class="max-w-7xl mx-auto px-6">
      <!-- Hero Section -->
      <header class="mb-20 text-center max-w-4xl mx-auto">
        <span
          class="text-primary font-bold tracking-[0.3em] uppercase text-xs mb-3 block"
          >Join Our Team</span
        >
        <h1
          class="font-display text-5xl md:text-7xl font-bold text-secondary mb-8 leading-tight italic uppercase"
        >
          BUILD YOUR <span class="not-italic text-primary">FUTURE</span> WITH US
        </h1>
        <p class="text-slate-500 text-lg md:text-xl leading-relaxed">
          At Dharma Putra Sejahtera Abadi, we blend technology and artistry to
          create exceptional interior experiences. We're looking for passionate
          individuals who strive for excellence and innovation.
        </p>
      </header>

      <!-- Career Categories -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Internship Section -->
        <div
          class="group bg-white rounded-3xl p-8 md:p-12 shadow-sm border border-zinc-100 hover:shadow-2xl transition-all duration-500 relative overflow-hidden"
        >
          <div
            class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-bl-full -mr-16 -mt-16 group-hover:scale-150 transition-transform duration-700"
          >
          </div>

          <div class="relative z-10">
            <div
              class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center text-primary mb-8 group-hover:bg-primary group-hover:text-white transition-colors duration-500"
            >
              <span class="material-icons-outlined text-3xl">school</span>
            </div>

            <h2
              class="font-display text-3xl font-bold text-secondary mb-4 uppercase"
            >
              Internship Program
            </h2>
            <p class="text-slate-600 mb-8 leading-relaxed">
              Are you a student or fresh graduate looking to jumpstart your
              career in interior design or engineering? Our internship program
              offers hands-on experience with real-world projects, guided by
              industry experts.
            </p>

            <ul class="space-y-4 mb-10">
              <li class="flex items-start gap-3 text-slate-500 text-sm">
                <span
                  class="material-icons-outlined text-accent-orange text-sm mt-0.5"
                  >check_circle</span
                >
                <span class="text-accent-orange/90"
                  >Minimum 3 months commitment</span
                >
              </li>
              <li class="flex items-start gap-3 text-slate-500 text-sm">
                <span
                  class="material-icons-outlined text-accent-orange text-sm mt-0.5"
                  >check_circle</span
                >
                <span class="text-accent-orange/90"
                  >Mentorship from senior designers & engineers</span
                >
              </li>
              <li class="flex items-start gap-3 text-slate-500 text-sm">
                <span
                  class="material-icons-outlined text-accent-orange text-sm mt-0.5"
                  >check_circle</span
                >
                <span class="text-accent-orange/90"
                  >Certificate and potential for full-time offer</span
                >
              </li>
            </ul>

            <a
              href="/careers/internships"
              class="inline-flex items-center gap-3 bg-secondary text-white px-8 py-4 rounded-sm font-bold hover:bg-primary transition-all tracking-widest text-xs uppercase"
            >
              Apply for Internship
              <span class="material-icons-outlined text-sm">arrow_forward</span>
            </a>
          </div>
        </div>

        <!-- Staff Careers Section -->
        <div
          class="group bg-secondary rounded-3xl p-8 md:p-12 shadow-sm border border-white/10 hover:shadow-2xl transition-all duration-500 relative overflow-hidden text-white"
        >
          <div
            class="absolute top-0 right-0 w-32 h-32 bg-white/5 rounded-bl-full -mr-16 -mt-16 group-hover:scale-150 transition-transform duration-700"
          >
          </div>

          <div class="relative z-10">
            <div
              class="w-16 h-16 bg-white/10 rounded-2xl flex items-center justify-center text-white mb-8 group-hover:bg-primary transition-colors duration-500"
            >
              <span class="material-icons-outlined text-3xl">work</span>
            </div>

            <h2 class="font-display text-3xl font-bold mb-4 uppercase">
              Professional Roles
            </h2>
            <p class="text-slate-300 mb-8 leading-relaxed">
              Ready to take your professional journey to the next level? We are
              looking for experienced professionals to join our design,
              production, and management teams.
            </p>

            <ul class="space-y-4 mb-10">
              <li class="flex items-start gap-3 text-slate-400 text-sm">
                <span
                  class="material-icons-outlined text-accent-orange text-sm mt-0.5"
                  >check_circle</span
                >
                <span class="text-accent-orange/90"
                  >Competitive compensation and benefits</span
                >
              </li>
              <li class="flex items-start gap-3 text-slate-400 text-sm">
                <span
                  class="material-icons-outlined text-accent-orange text-sm mt-0.5"
                  >check_circle</span
                >
                <span class="text-accent-orange/90"
                  >Work with cutting-edge CNC technology</span
                >
              </li>
              <li class="flex items-start gap-3 text-slate-400 text-sm">
                <span
                  class="material-icons-outlined text-accent-orange text-sm mt-0.5"
                  >check_circle</span
                >
                <span class="text-accent-orange/90"
                  >Collaborative & innovative environment</span
                >
              </li>
            </ul>

            <div class="flex flex-col sm:flex-row gap-4">
              <a
                href="https://glints.com/"
                target="_blank"
                class="flex-1 flex items-center justify-center gap-3 bg-white text-secondary px-6 py-4 rounded-sm font-bold hover:bg-primary hover:text-white transition-all tracking-widest text-[10px] uppercase"
              >
                Find us on Glints
                <span class="material-icons-outlined text-sm">open_in_new</span>
              </a>
              <a
                href="https://www.jobstreet.co.id/"
                target="_blank"
                class="flex-1 flex items-center justify-center gap-3 border border-white/20 text-white px-6 py-4 rounded-sm font-bold hover:bg-white hover:text-secondary transition-all tracking-widest text-[10px] uppercase"
              >
                Find us on Jobstreet
                <span class="material-icons-outlined text-sm">open_in_new</span>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Why Work Here -->
      <section class="mt-32">
        <div class="text-center mb-16">
          <h2
            class="font-display text-4xl font-bold text-secondary uppercase italic"
          >
            Why join <span class="not-italic text-primary"
              >Dharma Putra Sejahtera Abadi?</span
            >
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          {
            [
              {
                title: "Innovation",
                desc: "Access to the latest manufacturing technology and design tools.",
                icon: "lightbulb",
              },
              {
                title: "Craftsmanship",
                desc: "A culture that respects and celebrates true artistic excellence.",
                icon: "draw",
              },
              {
                title: "Career Growth",
                desc: "Clear paths for performance-based advancement and learning.",
                icon: "trending_up",
              },
            ].map((item) => (
              <div class="text-center">
                <div class="w-16 h-16 bg-white shadow-lg rounded-full flex items-center justify-center text-primary mx-auto mb-6">
                  <span class="material-icons-outlined text-3xl">
                    {item.icon}
                  </span>
                </div>
                <h3 class="font-display text-xl font-bold text-secondary mb-3 uppercase">
                  {item.title}
                </h3>
                <p class="text-slate-500 text-sm leading-relaxed">
                  {item.desc}
                </p>
              </div>
            ))
          }
        </div>
      </section>
    </div>
  </main>

  <Footer />
</Layout>
