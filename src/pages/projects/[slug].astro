<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #e2e8f0;
    border-radius: 10px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: #cbd5e1;
  }
</style>

<script>
  import EmblaCarousel from "embla-carousel";
  import Autoplay from "embla-carousel-autoplay";
  import {
    getWatermarkedDataUrl,
    preloadWatermark,
    watermarkedCache,
  } from "../../utils/watermark.js";

  // Fitur Ghost Watermark: Tukar src saat klik kanan
  function initGhostWatermark() {
    const images = document.querySelectorAll(
      "#project-carousel img, .thumbnail-btn img",
    );

    images.forEach((img) => {
      if (!(img instanceof HTMLImageElement)) return;

      const originalSrc = img.src;
      let isWatermarked = false;

      // Preload watermark di background agar siap saat klik kanan
      if (originalSrc && !originalSrc.startsWith("data:")) {
        preloadWatermark(originalSrc);
      }

      // Gunakan mousedown agar swap terjadi SEBELUM context menu muncul
      img.addEventListener("mousedown", async (e) => {
        // Cek apakah klik kanan (button 2)
        if (e.button !== 2) return;

        if (isWatermarked || img.src.startsWith("data:")) return;

        try {
          // Coba ambil dari cache secara sinkronous dulu
          if (watermarkedCache.has(originalSrc)) {
            img.src = watermarkedCache.get(originalSrc);
            isWatermarked = true;
          } else {
            // Jika belum ada, fallback ke async (mungkin telat untuk menu, tapi dicoba)
            const watermarkedSrc = await getWatermarkedDataUrl(originalSrc);
            img.src = watermarkedSrc;
            isWatermarked = true;
          }

          // Kembalikan ke original setelah beberapa saat atau saat mouse pergi
          setTimeout(() => {
            if (isWatermarked && !img.matches(":hover")) {
              img.src = originalSrc;
              isWatermarked = false;
            }
          }, 3000); // 3 detik
        } catch (err) {
          console.error("Gagal menyiapkan watermark:", err);
        }
      });

      // Tetap handle contextmenu untuk memastikan tidak ada race condition aneh
      // dan mencegah menu default jika kita mau (tapi user mau save as, jadi jangan preventDefault)
      img.addEventListener("contextmenu", (e) => {
        // Jika belum ter-swap (misal cache belum siap), kita bisa coba swap di sini juga
        // tapi kemungkinannya kecil untuk berhasil masuk ke "Save Image" dialog browser
        // karena browser mungkin sudah mengambil referensi image sebelum event ini selesai.
      });

      img.addEventListener("mouseleave", () => {
        if (isWatermarked) {
          img.src = originalSrc;
          isWatermarked = false;
        }
      });

      // Tambahan: kembalikan saat menu ditutup/klik di tempat lain (mouseup)
      window.addEventListener("mouseup", () => {
        // Optional: bisa langsung disable watermark kalau dilepas kliknya?
        // Tapi context menu tetap terbuka. Jadi biarkan timer atau mouseleave yang handle.
      });
    });
  }

  // Jalankan inisialisasi
  initGhostWatermark();

  const emblaNode = document.querySelector(".embla") as HTMLElement;
  const viewportNode = emblaNode?.querySelector(
    ".embla__container",
  ) as HTMLElement;
  const prevBtn = document.querySelector(".embla__prev") as HTMLElement;
  const nextBtn = document.querySelector(".embla__next") as HTMLElement;
  const dotsNode = document.querySelector(".embla__dots") as HTMLElement;
  const thumbnails = document.querySelectorAll(".thumbnail-btn");

  if (emblaNode && viewportNode) {
    const options = { loop: true, align: "start" as const };
    const plugins = [Autoplay({ delay: 4000, stopOnInteraction: false })];
    const emblaApi = EmblaCarousel(emblaNode, options, plugins);

    // Navigation
    if (prevBtn)
      prevBtn.addEventListener("click", () => emblaApi.scrollPrev(), false);
    if (nextBtn)
      nextBtn.addEventListener("click", () => emblaApi.scrollNext(), false);

    // Dots Generation
    const slideCount = emblaApi.scrollSnapList().length;
    if (slideCount > 1) {
      // Clear existing dots first (safeguard)
      dotsNode.innerHTML = "";

      const dots: HTMLElement[] = [];
      for (let i = 0; i < slideCount; i++) {
        const dot = document.createElement("button");
        dot.classList.add(
          "w-2",
          "h-2",
          "rounded-full",
          "bg-white/50",
          "transition-all",
          "duration-300",
        );
        if (i === 0) dot.classList.add("w-6", "bg-white"); // Active state init
        dot.addEventListener("click", () => emblaApi.scrollTo(i));
        dotsNode.appendChild(dot);
        dots.push(dot);
      }

      const updateDots = () => {
        const selectedIndex = emblaApi.selectedScrollSnap();
        dots.forEach((dot, index) => {
          if (index === selectedIndex) {
            dot.classList.add("w-6", "bg-white");
            dot.classList.remove("bg-white/50");
          } else {
            dot.classList.remove("w-6", "bg-white");
            dot.classList.add("bg-white/50");
          }
        });

        // Update thumbnails active state
        if (thumbnails.length > 0) {
          thumbnails.forEach((thumb, index) => {
            if (index === selectedIndex) {
              thumb.classList.add("border-accent-orange", "opacity-100");
              thumb.classList.remove("border-transparent", "opacity-60");
              thumb.scrollIntoView({
                behavior: "smooth",
                block: "nearest",
                inline: "center",
              });
            } else {
              thumb.classList.remove("border-accent-orange", "opacity-100");
              thumb.classList.add("border-transparent", "opacity-60");
            }
          });
        }
      };

      emblaApi.on("select", updateDots);
      emblaApi.on("init", updateDots);
    }

    // Thumbnails Click
    thumbnails.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        const index = parseInt(thumb.getAttribute("data-index") || "0");
        emblaApi.scrollTo(index);
      });
    });
  }
</script>
