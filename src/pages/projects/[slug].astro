  return projects.map((project, index) => {
    let gallery = [];
    let allImages = [];

    // First, try to find local images in the folder
    if (project.folderName) {
      try {
        const galleryPath = path.join(
          process.cwd(),
          "public",
          "images",
          "project",
          project.folderName,
        );
        if (fs.existsSync(galleryPath)) {
          const files = fs.readdirSync(galleryPath);
          const galleryFiles = files
            .filter((file) => {
              const ext = path.extname(file).toLowerCase();
              return [".jpg", ".jpeg", ".png", ".webp"].includes(ext);
            })
            .map((file) => `/images/project/${project.folderName}/${file}`);

          gallery = galleryFiles;
          allImages = [...galleryFiles];
        }
      } catch (e) {
        console.error(`Error loading gallery for ${project.title}:`, e);
      }
    }

    // If no local images were found in the folder, use the defined project.image
    // But if project.image is an Unsplash link, and we have NO local images, we'll keep it as fallback for now
    // BUT the user said NO fake photos, so let's filter them out if possible.
    if (
      allImages.length === 0 &&
      project.image &&
      !project.image.includes("unsplash.com")
    ) {
      allImages = [project.image];
    } else if (allImages.length === 0) {
      // Last resort: a very neutral placeholder or just an empty array
      allImages = [
        project.image || "https://placehold.co/1200x800?text=Image+Coming+Soon",
      ];
    }

    const prevProject = index > 0 ? projects[index - 1] : null;
    const nextProject =
      index < projects.length - 1 ? projects[index + 1] : null;

    return {
      params: { slug: project.slug },
      props: {
        project: { ...project, gallery, allImages, image: allImages[0] },
        prevProject: prevProject
          ? { title: prevProject.title, slug: prevProject.slug }
          : null,
        nextProject: nextProject
          ? { title: nextProject.title, slug: nextProject.slug }
          : null,
      },
    };
  });
}

const { project, prevProject, nextProject } = Astro.props;
---

<Layout title={`${project.title} | Dharma Putra Sejahtera Abadi`}>
  <Navbar />

  <main class="min-h-[calc(100vh-80px)]">
    <!-- Sticky Navigation Sub-header -->
    <div
      class="sticky top-[73px] z-30 bg-white/80 backdrop-blur-sm border-b border-zinc-100 mb-12"
    >
      <div
        class="max-w-7xl mx-auto px-6 py-6 flex flex-col md:flex-row md:items-center justify-between gap-6"
      >
        <a
          href="/projects"
          class="inline-flex items-center gap-2 text-accent-orange hover:gap-4 transition-all font-medium shrink-0"
        >
          <span class="material-icons-outlined">arrow_back</span>
          <span>BACK TO PORTFOLIO</span>
        </a>

        <div class="flex items-center gap-4 md:gap-8 overflow-hidden">
          {
            prevProject && (
              <a
                href={`/projects/${prevProject.slug}`}
                class="flex flex-col text-secondary hover:text-accent-orange transition-colors group min-w-0 max-w-[180px] lg:max-w-xs"
                title={prevProject.title}
              >
                <span class="text-[10px] uppercase tracking-widest text-slate-400 font-bold mb-1">
                  Previous
                </span>
                <div class="flex items-center gap-1 text-sm font-bold">
                  <span class="material-icons-outlined group-hover:-translate-x-1 transition-transform shrink-0">
                    chevron_left
                  </span>
                  <span class="truncate">{prevProject.title}</span>
                </div>
              </a>
            )
          }

          {
            prevProject && nextProject && (
              <div class="w-px h-8 bg-zinc-200 shrink-0" />
            )
          }

          {
            nextProject && (
              <a
                href={`/projects/${nextProject.slug}`}
                class="flex flex-col items-end text-secondary hover:text-accent-orange transition-colors group min-w-0 max-w-[180px] lg:max-w-xs text-right"
                title={nextProject.title}
              >
                <span class="text-[10px] uppercase tracking-widest text-slate-400 font-bold mb-1">
                  Next Project
                </span>
                <div class="flex items-center gap-1 text-sm font-bold">
                  <span class="truncate">{nextProject.title}</span>
                  <span class="material-icons-outlined group-hover:translate-x-1 transition-transform shrink-0">
                    chevron_right
                  </span>
                </div>
              </a>
            )
          }
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 pb-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
        <!-- Project Image Carousel (Fixed/Sticky) -->
        <div class="lg:col-span-7 lg:sticky lg:top-[180px]">
          <div
            class="rounded-2xl overflow-hidden shadow-xl aspect-[3/2] bg-zinc-100 relative group"
          >
            <div class="embla w-full h-full" id="project-carousel">
              <div class="embla__container flex h-full">
                {
                  project.allImages && project.allImages.length > 0 ? (
                    project.allImages.map((imgSrc, index) => (
                      <div class="embla__slide flex-[0_0_100%] min-w-0 h-full relative">
                        <img
                          src={imgSrc}
                          alt={`${project.title} - Image ${index + 1}`}
                          class="w-full h-full object-cover"
                          loading={index === 0 ? "eager" : "lazy"}
                          onerror="this.src='https://placehold.co/1200x800?text=Image+Not+Found'"
                        />
                        <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-black/60 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
                      </div>
                    ))
                  ) : (
                    <div class="embla__slide flex-[0_0_100%] min-w-0 h-full">
                      <img
                        src="https://placehold.co/1200x800?text=No+Image+Available"
                        alt="No Image"
                        class="w-full h-full object-cover"
                      />
                    </div>
                  )
                }
              </div>
            </div>

            <!-- Navigation Buttons -->
            <button
              class="embla__prev absolute left-4 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-white/90 backdrop-blur-sm shadow-md flex items-center justify-center text-accent-orange opacity-0 group-hover:opacity-100 transition-opacity duration-300 hover:bg-white z-10"
              aria-label="Previous slide"
            >
              <span class="material-icons-outlined text-sm">chevron_left</span>
            </button>
            <button
              class="embla__next absolute right-4 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-white/90 backdrop-blur-sm shadow-md flex items-center justify-center text-accent-orange opacity-0 group-hover:opacity-100 transition-opacity duration-300 hover:bg-white z-10"
              aria-label="Next slide"
            >
              <span class="material-icons-outlined text-sm">chevron_right</span>
            </button>

            <!-- Dots/Pagination -->
            <div
              class="embla__dots absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-1.5 z-10"
            >
