---
const { isSolid = false } = Astro.props;
---

<nav
  class="fixed top-0 left-0 w-full z-50 transition-all duration-700 ease-in-out group/nav"
  id="main-nav"
  data-is-solid={isSolid ? "true" : "false"}
>
  <div
    class="max-w-7xl mx-auto px-6 py-5 transition-all duration-500 ease-in-out flex justify-between items-center relative z-50"
    id="nav-container"
  >
    <div class="flex items-center gap-2">
      <a
        href="/#home"
        class="flex items-center group transition-transform duration-300 hover:scale-105 active:scale-95"
      >
        <!-- Logo Image: Swaps based on scroll state via JS -->
        <div class="relative h-10 md:h-12 w-auto">
          <img
            src="/images/DPSA2.png"
            alt="Dharma Putra Sejahtera Abadi Logo White"
            class="relative h-full w-auto object-contain transition-all duration-500 opacity-100 scale-100"
            id="nav-logo-white"
          />
          <img
            src="/images/DPSA2.png"
            alt="Dharma Putra Sejahtera Abadi Logo Color"
            class="absolute top-0 left-0 h-full w-auto object-contain transition-all duration-500 opacity-0 scale-90"
            id="nav-logo-color"
          />
        </div>
        <span
          class="ml-3 text-lg md:text-xl font-sans font-bold text-white transition-all duration-500 tracking-tight"
          id="nav-title"
        >
          <span class="transition-colors duration-500" id="nav-brand-highlight"
            >DPSA</span
          >
        </span>
      </a>
    </div>

    <!-- Desktop Menu -->
    <div class="hidden md:flex items-center gap-1">
      {
        [
          { href: "/#home", text: "Home" },
          { href: "/#about", text: "About" },
          { href: "/#subsidiaries", text: "Subsidiaries" },
          { href: "/#projects", text: "Projects" },
          { href: "/articles", text: "Article" },
          // { href: "/#client", text: "Clients" },
          { href: "/careers", text: "Careers" },
          {
            href: "https://www.trackingorderdpsa.xyz/",
            text: "Track Order",
            external: true,
          },
        ].map((item) => (
          <a
            href={item.href}
            target={item.external ? "_blank" : undefined}
            class="nav-link relative text-[13px] font-bold text-white/90 hover:text-white transition-all duration-300 uppercase tracking-widest px-4 py-2 rounded-full hover:bg-white/10"
          >
            {item.text}
            <span class="absolute bottom-1 left-1/2 -translate-x-1/2 w-0 h-[2px] bg-accent-orange transition-all duration-300 group-hover:w-1/2 opacity-0 group-hover:opacity-100" />
          </a>
        ))
      }
      <div class="ml-4 pl-4 border-l border-white/10" id="nav-divider">
        <a
          href="https://wa.me/6281128507788"
          target="_blank"
          class="bg-white text-primary-dark text-[11px] font-black uppercase shadow-white/10 tracking-[0.15em] px-7 py-3 rounded-full hover:bg-accent-orange hover:text-white transition-all duration-500 transform hover:-translate-y-1 active:scale-95 shadow-xl inline-block"
          id="nav-cta"
        >
          Contact Us
        </a>
      </div>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="menu-toggle"
      class="p-2 text-white md:hidden group transition-all duration-300 hover:bg-white/10 rounded-xl"
    >
      <div
        class="w-6 h-4 flex flex-col justify-between items-end overflow-hidden"
      >
        <span
          class="menu-bar w-full h-0.5 bg-current rounded-full transition-all duration-300 group-hover:translate-x-1"
        ></span>
        <span
          class="menu-bar w-3/4 h-0.5 bg-current rounded-full transition-all duration-300"
        ></span>
        <span
          class="menu-bar w-full h-0.5 bg-current rounded-full transition-all duration-300 group-hover:-translate-x-1"
        ></span>
      </div>
    </button>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 bg-white/95 backdrop-blur-2xl z-[60] transform translate-y-full opacity-0 invisible transition-all duration-700 ease-[cubic-bezier(0.85,0,0.15,1)] md:hidden flex flex-col w-full h-screen"
  >
    <!-- Mobile Header -->
    <div class="flex justify-between items-center px-8 py-8">
      <a href="/#home" class="flex items-center gap-3">
        <img
          src="/images/DPSA2.png"
          alt="Dharma Putra Sejahtera Abadi Logo"
          class="h-10 w-auto object-contain"
        />
        <span
          class="text-xl font-sans font-black text-primary-dark tracking-tighter"
        >
          DPSA
        </span>
      </a>
      <button
        id="close-menu"
        class="w-12 h-12 flex items-center justify-center rounded-2xl bg-slate-100 text-primary-dark hover:bg-primary-dark hover:text-white transition-all duration-500"
      >
        <span class="material-icons-outlined text-2xl">close</span>
      </button>
    </div>

    <!-- Mobile Scrollable Content -->
    <div
      class="flex-1 overflow-y-auto px-10 py-6 flex flex-col justify-between"
    >
      <div class="flex flex-col gap-2">
        {
          [
            { href: "/#home", text: "Home", icon: "home" },
            { href: "/#about", text: "About Us", icon: "info" },
            { href: "/#subsidiaries", text: "Subsidiaries", icon: "business" },
            { href: "/#projects", text: "Projects", icon: "work" },
            { href: "/articles", text: "Article", icon: "article" },
            { href: "/#client", text: "Clients", icon: "group" },
            { href: "/careers", text: "Careers", icon: "person_search" },
            {
              href: "https://www.trackingorderdpsa.xyz/",
              text: "Track Order",
              icon: "location_searching",
              external: true,
            },
          ].map((item, index) => (
            <a
              href={item.href}
              target={item.external ? "_blank" : undefined}
              class="mobile-link group flex items-center justify-between py-4 border-b border-slate-100 translate-y-10 opacity-0 transition-all duration-700"
              style={`transition-delay: ${index * 70}ms;`}
            >
              <span class="text-3xl font-display font-black text-slate-800 group-hover:text-primary transition-colors">
                {item.text}
              </span>
              <div class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-slate-400 group-hover:bg-primary group-hover:text-white transition-all duration-500">
                <span class="material-icons-outlined text-sm">{item.icon}</span>
              </div>
            </a>
          ))
        }
      </div>

      <div
        class="pb-12 translate-y-10 opacity-0 transition-all duration-700 delay-[500ms]"
        id="mobile-footer"
      >
        <div class="flex flex-col gap-6">
          <div class="space-y-1">
            <p
              class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-black"
            >
              Quick Action
            </p>
            <div class="h-1 w-8 bg-primary rounded-full"></div>
          </div>
          <a
            href="https://wa.me/6281128507788"
            target="_blank"
            class="flex items-center gap-5 p-5 bg-primary rounded-3xl text-white shadow-2xl shadow-primary/30 group hover:scale-[1.02] transition-transform"
          >
            <div
              class="w-14 h-14 bg-white/20 backdrop-blur-md flex items-center justify-center rounded-2xl text-white"
            >
              <span class="material-icons-outlined text-2xl">chat</span>
            </div>
            <div>
              <p class="text-xs opacity-70 font-medium">WhatsApp Support</p>
              <p class="font-black text-lg">0811-2850-7788</p>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>

  <script>
    const menuToggle = document.getElementById("menu-toggle");
    const closeMenu = document.getElementById("close-menu");
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileLinks = document.querySelectorAll(".mobile-link");
    const mobileFooter = document.getElementById("mobile-footer");

    // Desktop Nav Elements
    const mainNav = document.getElementById("main-nav");
    const navContainer = document.getElementById("nav-container");
    const navLogoWhite = document.getElementById("nav-logo-white");
    const navLogoColor = document.getElementById("nav-logo-color");
    const navTitle = document.getElementById("nav-title");
    const navLinks = document.querySelectorAll(".nav-link");
    const navCta = document.getElementById("nav-cta");
    const navDivider = document.getElementById("nav-divider");

    // Scroll Behavior
    const handleScroll = () => {
      const isSolid = mainNav?.getAttribute("data-is-solid") === "true";

      if (window.scrollY > 80 || isSolid) {
        // Floating Capsule State
        mainNav?.classList.add("pt-4");
        navContainer?.classList.remove("max-w-7xl", "py-5", "px-6");
        navContainer?.classList.add(
          "max-w-7xl",
          "py-3",
          "px-8",
          "bg-white/80",
          "backdrop-blur-xl",
          "rounded-full",
          "shadow-[0_20px_50px_rgba(0,0,0,0.1)]",
          "border",
          "border-white/40",
        );

        // Logo Switch & Scale
        navLogoWhite?.classList.remove("opacity-100", "scale-100");
        navLogoWhite?.classList.add("opacity-0", "scale-90");
        navLogoColor?.classList.remove("opacity-0", "scale-90");
        navLogoColor?.classList.add("opacity-100", "scale-100");

        // Text Colors
        navTitle?.classList.remove("text-white");
        navTitle?.classList.add("text-primary-dark");

        // Links
        navLinks.forEach((link) => {
          link.classList.remove(
            "text-white/90",
            "hover:text-white",
            "hover:bg-white/10",
          );
          link.classList.add(
            "text-slate-600",
            "hover:text-primary-dark",
            "hover:bg-slate-100",
          );
        });

        // CTA Button
        navCta?.classList.remove(
          "bg-white",
          "text-primary-dark",
          "shadow-white/10",
        );
        navCta?.classList.add(
          "bg-primary-dark",
          "text-white",
          "shadow-primary-dark/20",
        );

        // Divider
        navDivider?.classList.remove("border-white/10");
        navDivider?.classList.add("border-slate-200");

        // Mobile Menu Button
        menuToggle?.classList.remove("text-white");
        menuToggle?.classList.add("text-primary-dark", "hover:bg-slate-100");
      } else {
        // Top State (Full transparency)
        mainNav?.classList.remove("pt-4");
        navContainer?.classList.add("max-w-7xl", "py-5", "px-6");
        navContainer?.classList.remove(
          "max-w-7xl",
          "py-3",
          "px-8",
          "bg-white/80",
          "backdrop-blur-xl",
          "rounded-full",
          "shadow-[0_20px_50px_rgba(0,0,0,0.1)]",
          "border",
          "border-white/40",
        );

        // Logo Switch & Scale
        navLogoWhite?.classList.add("opacity-100", "scale-100");
        navLogoWhite?.classList.remove("opacity-0", "scale-90");
        navLogoColor?.classList.add("opacity-0", "scale-90");
        navLogoColor?.classList.remove("opacity-100", "scale-100");

        // Text Colors
        navTitle?.classList.add("text-white");
        navTitle?.classList.remove("text-primary-dark");

        // Links
        navLinks.forEach((link) => {
          link.classList.add(
            "text-white/90",
            "hover:text-white",
            "hover:bg-white/10",
          );
          link.classList.remove(
            "text-slate-600",
            "hover:text-primary-dark",
            "hover:bg-slate-100",
          );
        });

        // CTA Button
        navCta?.classList.add(
          "bg-white",
          "text-primary-dark",
          "shadow-white/10",
        );
        navCta?.classList.remove(
          "bg-primary-dark",
          "text-white",
          "shadow-primary-dark/20",
        );

        // Divider
        navDivider?.classList.add("border-white/10");
        navDivider?.classList.remove("border-slate-200");

        // Mobile Menu Button
        menuToggle?.classList.add("text-white");
        menuToggle?.classList.remove("text-primary-dark", "hover:bg-slate-100");
      }
    };

    window.addEventListener("scroll", handleScroll);
    handleScroll();

    const toggleMenu = (open: boolean) => {
      if (open) {
        mobileMenu?.classList.remove(
          "translate-y-full",
          "opacity-0",
          "invisible",
        );
        document.body.style.overflow = "hidden";

        // Animate items in
        setTimeout(() => {
          mobileLinks.forEach((link) => {
            link.classList.remove("translate-y-10", "opacity-0");
          });
          mobileFooter?.classList.remove("translate-y-10", "opacity-0");
        }, 100);
      } else {
        mobileMenu?.classList.add("translate-y-full", "opacity-0");
        document.body.style.overflow = "";

        // Reset animation state after transition
        setTimeout(() => {
          mobileMenu?.classList.add("invisible");
          mobileLinks.forEach((link) => {
            link.classList.add("translate-y-10", "opacity-0");
          });
          mobileFooter?.classList.add("translate-y-10", "opacity-0");
        }, 700);
      }
    };

    menuToggle?.addEventListener("click", () => toggleMenu(true));
    closeMenu?.addEventListener("click", () => toggleMenu(false));

    mobileLinks.forEach((link) => {
      link.addEventListener("click", () => toggleMenu(false));
    });
  </script>
</nav>
