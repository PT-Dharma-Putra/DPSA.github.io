---
const subsidiaries = [
  { name: "Aston Kemayoran", logo: "/images/client/Aston Kemayoran.png" },
  { name: "Hamori", logo: "/images/client/Hamori.png" },
  { name: "Hazna Medika", logo: "/images/client/Hazna Medika.png" },
  { name: "Hermina", logo: "/images/client/Hermina.png" },
  { name: "Kopi TM", logo: "/images/client/Kopi TM.png" },
  { name: "Luminor", logo: "/images/client/Luminor.png" },
  { name: "Mataram City", logo: "/images/client/Mataram.png" },
  { name: "Patraland", logo: "/images/client/Patraland.png" },
  { name: "Punika Deli", logo: "/images/client/Punika Deli.png" },
  { name: "Royal Ambarukmo", logo: "/images/client/Royal Ambarukmo.png" },
  { name: "RS JIH", logo: "/images/client/RS JIH.png" },
  { name: "RS Panti Rapih", logo: "/images/client/RS Panti Rapih.png" },
  { name: "RS Provita", logo: "/images/client/RS Provita.png" },
  { name: "RS Ubaya", logo: "/images/client/RS Ubaya.png" },
];

// Double the items for a seamless loop
const scrollItems = [...subsidiaries, ...subsidiaries];
---

<section id="client" class="py-24 bg-background-light overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 mb-16 text-center">
    <div
      class="inline-block mb-4 px-4 py-1 rounded-full bg-primary/10 text-primary text-[0.7rem] font-bold uppercase tracking-[0.2em]"
      data-aos="fade-down"
    >
      Trusted By
    </div>
    <h2
      class="text-4xl md:text-5xl font-display font-bold text-secondary italic"
      data-aos="fade-up"
      data-aos-delay="200"
    >
      Our <span class="text-gradient-gold not-italic">Clients</span>
    </h2>
  </div>

  <div
    class="relative w-full overflow-hidden before:absolute before:left-0 before:top-0 before:z-10 before:h-full before:w-32 before:bg-gradient-to-r before:from-background-light before:to-transparent after:absolute after:right-0 after:top-0 after:z-10 after:h-full after:w-32 after:bg-gradient-to-l after:from-background-light after:to-transparent"
    data-aos="fade-in"
    data-aos-delay="400"
  >
    <div class="flex animate-marquee hover:pause whitespace-nowrap py-12">
      {
        scrollItems.map((item) => (
          <div class="flex-shrink-0 mx-10 md:mx-16 lg:mx-20 flex items-center justify-center grayscale hover:grayscale-0 transition-all duration-500 hover:scale-110">
            <img
              src={item.logo}
              alt={item.name}
              class="h-16 md:h-24 lg:h-28 w-auto object-contain filter drop-shadow-sm"
              loading="lazy"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .animate-marquee {
    animation: marquee 30s linear infinite;
    display: flex;
    width: max-content;
  }

  .hover\:pause:hover {
    animation-play-state: paused;
  }
</style>
