<script>
  import EmblaCarousel from "embla-carousel";
  import Autoplay from "embla-carousel-autoplay";

  const setupProcessCarousel = () => {
    const emblaNode = document.querySelector(
      "#process-carousel",
    ) as HTMLElement;
    const viewportNode = emblaNode?.querySelector(
      ".embla__container",
    ) as HTMLElement;
    const dotsNode = document.querySelector("#process-dots") as HTMLElement;
    const prevBtn = document.querySelector("#process-prev") as HTMLElement;
    const nextBtn = document.querySelector("#process-next") as HTMLElement;

    if (!emblaNode || !viewportNode) return;

    const isMobile = () => window.innerWidth < 768;

    let emblaApi: any;

    const initEmbla = () => {
      if (isMobile() && !emblaApi) {
        emblaApi = EmblaCarousel(emblaNode, { loop: true, align: "start" }, [
          Autoplay({ delay: 6000, stopOnInteraction: false }),
        ]);

        const slides = emblaApi.scrollSnapList();
        dotsNode.innerHTML = slides
          .map(
            () =>
              `<button class="w-2 h-2 rounded-full bg-primary/20 transition-all duration-300"></button>`,
          )
          .join("");

        const dots = Array.from(dotsNode.children) as HTMLElement[];

        const updateDots = () => {
          const selected = emblaApi.selectedScrollSnap();
          dots.forEach((dot, i) => {
            if (i === selected) {
              dot.classList.add("w-6", "bg-accent-orange");
              dot.classList.remove("bg-accent-orange/20");
            } else {
              dot.classList.remove("w-6", "bg-accent-orange");
              dot.classList.add("bg-accent-orange/20");
            }
          });
        };

        emblaApi.on("select", updateDots);
        emblaApi.on("init", updateDots);
        updateDots();

        dots.forEach((dot, i) => {
          dot.addEventListener("click", () => emblaApi.scrollTo(i));
        });

        // Button listeners
        if (prevBtn)
          prevBtn.addEventListener("click", () => emblaApi.scrollPrev());
        if (nextBtn)
          nextBtn.addEventListener("click", () => emblaApi.scrollNext());
      } else if (!isMobile() && emblaApi) {
        emblaApi.destroy();
        emblaApi = null;
        if (dotsNode) dotsNode.innerHTML = "";
      }
    };

    initEmbla();
    window.addEventListener("resize", initEmbla);
  };

  document.addEventListener("DOMContentLoaded", setupProcessCarousel);
  document.addEventListener("astro:page-load", setupProcessCarousel);
</script>
