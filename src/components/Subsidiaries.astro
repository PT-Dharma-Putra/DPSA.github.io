---
const subsidiaries = [
  {
    name: "CV Dharma Chipta Archidium",
    logo: "/images/subsidiaries/Cv_Dharma_Chipta_Archidium-removebg-preview.png",
  },
  {
    name: "PT Dharma Putra Sejahtera Abadi",
    logo: "/images/subsidiaries/Pt_Abhijati_Sahar_Dharma-removebg-preview.png",
    website: "https://abhijatidharma.co.id",
  },
  {
    name: "PT Kartika Jaya Ananda",
    logo: "/images/subsidiaries/Pt_Kartika_Jaya_Ananda-removebg-preview.png",
    website: "https://kartikasofa.co.id",
  },
  {
    name: "PT Kartika Pawenang Sukses Abadi",
    logo: "/images/subsidiaries/Pt_Kartika_Pawenang_Sukses_Abadi-removebg-preview.png",
    website: "https://kartikasofa.co.id",
  },
  {
    name: "PT Sinergi Muda Berkarya",
    logo: "/images/subsidiaries/Pt_Sinergi_Muda_Berkarya-removebg-preview.png",
  },
  {
    name: "PT Sorajati Dharma Biru",
    logo: "/images/subsidiaries/Pt_Sorajati_Dharma_Biru-removebg-preview.png",
    website: "https://sorajati.co.id",
  },
  {
    name: "PT Swastika Suraga Dharma",
    logo: "/images/subsidiaries/Pt_Swastika_Suraga_Dharma-removebg-preview.png",
  },
  {
    name: "PT Unggul Inovasi",
    logo: "/images/subsidiaries/Pt_Unggul_Inovasi-removebg-preview.png",
  },
];

// Double the items for a seamless loop
const scrollItems = [...subsidiaries, ...subsidiaries];
---

<section
  id="subsidiaries"
  class="py-20 bg-background-light overflow-hidden border-t border-primary/5"
>
  <div class="max-w-7xl mx-auto px-6 mb-16 text-center">
    <div
      class="inline-block mb-4 px-4 py-1 rounded-full bg-primary/10 text-primary text-[0.7rem] font-bold uppercase tracking-[0.2em]"
    >
      Our Network
    </div>
    <h2
      class="text-4xl md:text-5xl font-display font-bold text-secondary italic"
    >
      Our <span class="text-gradient-primary not-italic">Subsidiaries</span>
    </h2>
  </div>

  <div
    class="relative w-full overflow-hidden before:absolute before:left-0 before:top-0 before:z-10 before:h-full before:w-32 before:bg-gradient-to-r before:from-background-light before:to-transparent after:absolute after:right-0 after:top-0 after:z-10 after:h-full after:w-32 after:bg-gradient-to-l after:from-background-light after:to-transparent"
  >
    <div class="flex animate-marquee hover:pause whitespace-nowrap py-10">
      {
        scrollItems.map((item) => (
          <div class="flex-shrink-0 mx-10 md:mx-16 lg:mx-20 flex items-center justify-center grayscale hover:grayscale-0 transition-all duration-500 hover:scale-110">
            {item.website ? (
              <a
                href={item.website}
                target="_blank"
                rel="noopener noreferrer"
                class="block cursor-pointer"
                title={`Visit ${item.name} website`}
              >
                <img
                  src={item.logo}
                  alt={item.name}
                  class="h-12 md:h-16 lg:h-20 w-auto object-contain filter drop-shadow-sm"
                  loading="lazy"
                />
              </a>
            ) : (
              <img
                src={item.logo}
                alt={item.name}
                class="h-12 md:h-16 lg:h-20 w-auto object-contain filter drop-shadow-sm"
                loading="lazy"
              />
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .animate-marquee {
    animation: marquee 30s linear infinite;
    display: flex;
    width: max-content;
  }

  .hover\:pause:hover {
    animation-play-state: paused;
  }
</style>
