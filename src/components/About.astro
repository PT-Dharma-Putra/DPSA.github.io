<script>
  import {
    getWatermarkedDataUrl,
    preloadWatermark,
    watermarkedCache,
  } from "../utils/watermark.js";

  function initAboutWatermark() {
    const img = document.querySelector("#about img");

    if (!img || !(img instanceof HTMLImageElement)) return;

    const originalSrc = img.src;
    let isWatermarked = false;

    if (originalSrc && !originalSrc.startsWith("data:")) {
      preloadWatermark(originalSrc);
    }

    img.addEventListener("mousedown", async (e) => {
      if (e.button !== 2) return;
      if (isWatermarked || img.src.startsWith("data:")) return;

      try {
        if (watermarkedCache.has(originalSrc)) {
          img.src = watermarkedCache.get(originalSrc);
          isWatermarked = true;
        } else {
          const watermarkedSrc = await getWatermarkedDataUrl(originalSrc);
          img.src = watermarkedSrc;
          isWatermarked = true;
        }

        setTimeout(() => {
          if (isWatermarked && !img.matches(":hover")) {
            img.src = originalSrc;
            isWatermarked = false;
          }
        }, 3000);
      } catch (err) {
        console.error("Gagal menyiapkan watermark:", err);
      }
    });

    img.addEventListener("mouseleave", () => {
      if (isWatermarked) {
        img.src = originalSrc;
        isWatermarked = false;
      }
    });
  }

  document.addEventListener("DOMContentLoaded", initAboutWatermark);
  document.addEventListener("astro:page-load", initAboutWatermark);
</script>
