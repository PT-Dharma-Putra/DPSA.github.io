  <div class="absolute inset-0 z-0">
    <img
      class="w-full h-full object-cover scale-105 animate-slow-zoom"
      src="/images/Poster Hero Section.png"
    />
    <div
      class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-background-light/10 pointer-events-none"
    >
    </div>
  </div>

  <div class="relative z-10 w-full max-w-5xl text-center text-white">
    <div
      class="inline-block mb-6 px-4 py-1.5 rounded-full border border-accent-orange/30 bg-accent-orange/10 backdrop-blur-sm"
      data-aos="fade-down"
    >
      <span
        class="text-[0.7rem] md:text-xs font-bold uppercase tracking-[0.3em] text-accent-orange"
        >Established 1994</span
      >
    </div>

    <h1
      class="font-display text-5xl md:text-7xl lg:text-8xl font-bold mb-8 tracking-tight leading-[1.1]"
      data-aos="fade-up"
      data-aos-delay="200"
    >
      Dharma Putra<br />
      <span class="italic">Sejahtera Abadi</span>
    </h1>

    <p
      class="text-lg md:text-2xl text-white/80 mb-12 max-w-2xl mx-auto font-light tracking-wide leading-relaxed"
      data-aos="fade-up"
      data-aos-delay="400"
    >
      Crafting extraordinary environments through <span
        class="text-white font-medium">30 years</span
      > of precision design and masterful build expertise.
    </p>

    <div
      class="flex flex-col sm:flex-row gap-5 justify-center items-center"
      data-aos="zoom-in"
      data-aos-delay="600"
    >
      <a
        href="#projects"
        class="group relative overflow-hidden bg-white/10 hover:bg-white/20 backdrop-blur-md border border-white/20 text-white font-bold py-4 px-10 rounded-full transition-all duration-300 tracking-[0.15em] uppercase text-[0.7rem]"
      >
        <span class="relative z-10">Explore Our Project</span>
        <div
          class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"
        >
        </div>
      </a>
      <a
        href="https://wa.me/6281128507788"
        class="bg-accent-orange hover:bg-accent-orange/90 text-white font-bold py-4 px-10 rounded-full transition-all duration-300 shadow-xl shadow-accent-orange/20 hover:shadow-accent-orange/40 transform hover:-translate-y-1 active:scale-95 tracking-[0.15em] uppercase text-[0.7rem]"
      >
        Contact Us
