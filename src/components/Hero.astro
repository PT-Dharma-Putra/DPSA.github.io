<style>
  @keyframes slow-zoom {
    0% {
      transform: scale(1);
    }
    100% {
      transform: scale(1.1);
    }
  }

  @keyframes fade-in-up {
    0% {
      opacity: 0;
      transform: translateY(30px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fade-in {
    0% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }

  .animate-slow-zoom {
    animation: slow-zoom 20s ease-out forwards;
  }

  .animate-fade-in-up {
    animation: fade-in-up 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    opacity: 0;
  }

  .animate-fade-in {
    animation: fade-in 1.5s ease-out forwards;
  }

  .delay-200 {
    animation-delay: 200ms;
  }

  .delay-500 {
    animation-delay: 500ms;
  }
</style>

<script>
  import {
    getWatermarkedDataUrl,
    preloadWatermark,
    watermarkedCache,
  } from "../utils/watermark.js";

  function initHeroWatermark() {
    const img = document.querySelector("#home img");

    if (!img || !(img instanceof HTMLImageElement)) return;

    const originalSrc = img.src;
    let isWatermarked = false;

    if (originalSrc && !originalSrc.startsWith("data:")) {
      preloadWatermark(originalSrc);
    }

    img.addEventListener("contextmenu", async (e) => {
      if (isWatermarked || img.src.startsWith("data:")) return;

      try {
        if (watermarkedCache.has(originalSrc)) {
          img.src = watermarkedCache.get(originalSrc);
          isWatermarked = true;
        } else {
          const watermarkedSrc = await getWatermarkedDataUrl(originalSrc);
          img.src = watermarkedSrc;
          isWatermarked = true;
        }

        // Return to original after menu might have closed or after some time
        setTimeout(() => {
          if (isWatermarked) {
            img.src = originalSrc;
            isWatermarked = false;
          }
        }, 5000);
      } catch (err) {
        console.error("Gagal menyiapkan watermark:", err);
      }
    });

    img.addEventListener("mouseleave", () => {
      if (isWatermarked) {
        img.src = originalSrc;
        isWatermarked = false;
      }
    });
  }

  document.addEventListener("DOMContentLoaded", initHeroWatermark);
  document.addEventListener("astro:page-load", initHeroWatermark);
</script>
