<section
  id="video-profile"
  class="relative min-h-screen w-full bg-secondary overflow-hidden flex items-center"
>
  <!-- Decorative background elements -->
  <div class="absolute inset-0 w-full h-full">
    <!-- Abstract geometric shapes for a "firm" architectural look -->
    <div
      class="absolute top-0 right-0 w-1/2 h-full bg-[#1a1f2e] skew-x-12 origin-top transform translate-x-20"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 w-1/3 h-1/2 bg-white/5 rounded-tr-[100px]"
    >
    </div>
  </div>

  <div
    class="max-w-[1920px] mx-auto w-full px-6 lg:px-12 relative z-10 grid lg:grid-cols-2 gap-12 items-center h-full py-20 lg:py-0"
  >
    <!-- Left Content -->
    <div class="max-w-2xl lg:pl-12 order-2 lg:order-1">
      <div class="inline-block mb-6">
        <span
          class="py-2 px-4 border border-primary/30 rounded-full text-primary text-sm tracking-[0.2em] uppercase font-semibold bg-primary/5 backdrop-blur-sm"
        >
          Company Profile
        </span>
      </div>

      <h2
        class="font-display text-5xl lg:text-7xl font-bold text-white mb-8 leading-[1.1]"
      >
        Advanced <br />
        <span class="text-gradient-primary">Manufacturing</span>
        <br />
        Meets Artistry
      </h2>

      <div class="h-1 w-32 bg-primary mb-10"></div>

      <p
        class="text-slate-300 text-lg lg:text-xl leading-relaxed mb-12 max-w-xl"
      >
        Powered by state-of-the-art <strong class="text-white"
          >CNC machinery</strong
        > and precision engineering, we deliver superior speed and accuracy. Our integrated
        production facility combines modern technology with expert craftsmanship to
        create flawless interiors.
      </p>

      <div class="flex flex-col sm:flex-row gap-6">
        <div class="flex items-center gap-4">
          <div
            class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center text-primary"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"
              ></polyline></svg
            >
          </div>
          <div>
            <p class="text-white font-bold">High-Precision Tech</p>
            <p class="text-slate-400 text-sm">Automated CNC Systems</p>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <div
            class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center text-primary"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="2" y="3" width="20" height="14" rx="2" ry="2"
              ></rect><line x1="8" y1="21" x2="16" y2="21"></line><line
                x1="12"
                y1="17"
                x2="12"
                y2="21"></line></svg
            >
          </div>
          <div>
            <p class="text-white font-bold">Production Facility</p>
            <p class="text-slate-400 text-sm">Scale & Efficiency</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Content: Video -->
    <div
      class="relative h-full w-full flex items-center justify-center lg:justify-end order-1 lg:order-2"
    >
      <div
        class="relative w-full max-w-3xl aspect-video rounded-tr-[4rem] rounded-bl-[4rem] overflow-hidden shadow-2xl border-2 border-white/10 group"
      >
        <video
          class="w-full h-full object-cover"
          autoplay
          muted
          loop
          playsinline
          controls
          controlsList="nodownload"
          oncontextmenu="return false;"
        >
          <source
            src="/images/video/COMPRODPSA2-Gye-M2JolQxohf0DIkEDhw-OKAz89SOFslzKLglvGU_Ig.mp4"
            type="video/mp4"
          />
          Your browser does not support the video tag.
        </video>

        <!-- Decorative Frame Elements -->
        <div
          class="absolute -top-4 -right-4 w-24 h-24 border-t-4 border-r-4 border-primary rounded-tr-[2rem] opacity-60"
        >
        </div>
        <div
          class="absolute -bottom-4 -left-4 w-24 h-24 border-b-4 border-l-4 border-primary rounded-bl-[2rem] opacity-60"
        >
        </div>

        <!-- Watermark Overlay -->
        <div
          class="absolute bottom-6 right-6 z-20 pointer-events-none opacity-50 flex items-center gap-2"
        >
          <img
            src="/images/logo-watermark.png"
            class="h-12 w-auto"
            alt="Dharma Putra Sejahtera Abadi Watermark"
          />
          <span
            class="text-white/50 text-xs font-bold tracking-widest uppercase hidden sm:block"
            >Dharma Putra Sejahtera Abadi</span
          >
        </div>
      </div>
    </div>
  </div>
</section>
