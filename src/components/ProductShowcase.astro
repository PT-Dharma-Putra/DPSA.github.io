<script>
  import EmblaCarousel from "embla-carousel";
  import Autoplay from "embla-carousel-autoplay";
  import {
    getWatermarkedDataUrl,
    preloadWatermark,
    watermarkedCache,
  } from "../utils/watermark.js";

  // Fitur Ghost Watermark
  function initGhostWatermark() {
    const images = document.querySelectorAll("#projects-carousel img");

    images.forEach((img) => {
      if (!(img instanceof HTMLImageElement)) return;

      const originalSrc = img.src;
      let isWatermarked = false;

      if (originalSrc && !originalSrc.startsWith("data:")) {
        preloadWatermark(originalSrc);
      }

      img.addEventListener("mousedown", async (e) => {
        if (e.button !== 2) return;
        if (isWatermarked || img.src.startsWith("data:")) return;

        try {
          if (watermarkedCache.has(originalSrc)) {
            img.src = watermarkedCache.get(originalSrc);
            isWatermarked = true;
          } else {
            const watermarkedSrc = await getWatermarkedDataUrl(originalSrc);
            img.src = watermarkedSrc;
            isWatermarked = true;
          }

          setTimeout(() => {
            if (isWatermarked && !img.matches(":hover")) {
              img.src = originalSrc;
              isWatermarked = false;
            }
          }, 3000);
        } catch (err) {
          console.error("Gagal menyiapkan watermark:", err);
        }
      });

      img.addEventListener("mouseleave", () => {
        if (isWatermarked) {
          img.src = originalSrc;
          isWatermarked = false;
        }
      });
    });
  }

  const setupCarousel = () => {
    const emblaNode = document.querySelector(
      "#projects-carousel",
    ) as HTMLElement;
    const viewportNode = emblaNode?.querySelector(
      ".embla__container",
    ) as HTMLElement;
    const dotsNode = document.querySelector("#project-dots") as HTMLElement;
    const prevBtn = document.querySelector("#project-prev") as HTMLElement;
    const nextBtn = document.querySelector("#project-next") as HTMLElement;

    if (!emblaNode || !viewportNode) return;

    // Only activate Embla on small screens
    const isMobile = () => window.innerWidth < 768;

    let emblaApi: any;

    const initEmbla = () => {
      if (isMobile() && !emblaApi) {
        emblaApi = EmblaCarousel(emblaNode, { loop: true, align: "start" }, [
          Autoplay({ delay: 5000, stopOnInteraction: false }),
        ]);

        // Generate dots
        const slides = emblaApi.scrollSnapList();
        dotsNode.innerHTML = slides
          .map(
            () =>
              `<button class="w-2 h-2 rounded-full bg-primary/20 transition-all duration-300"></button>`,
          )
          .join("");

        const dots = Array.from(dotsNode.children) as HTMLElement[];

        const updateDots = () => {
          const selected = emblaApi.selectedScrollSnap();
          dots.forEach((dot, i) => {
            if (i === selected) {
              dot.classList.add("w-6", "bg-accent-orange");
              dot.classList.remove("bg-accent-orange/20");
            } else {
              dot.classList.remove("w-6", "bg-accent-orange");
              dot.classList.add("bg-accent-orange/20");
            }
          });
        };

        emblaApi.on("select", updateDots);
        emblaApi.on("init", updateDots);
        updateDots();

        dots.forEach((dot, i) => {
          dot.addEventListener("click", () => emblaApi.scrollTo(i));
        });

        // Button listeners
        if (prevBtn)
          prevBtn.addEventListener("click", () => emblaApi.scrollPrev());
        if (nextBtn)
          nextBtn.addEventListener("click", () => emblaApi.scrollNext());
      } else if (!isMobile() && emblaApi) {
        emblaApi.destroy();
        emblaApi = null;
        if (dotsNode) dotsNode.innerHTML = "";
      }
    };

    initEmbla();
    window.addEventListener("resize", initEmbla);
    initGhostWatermark();
  };

  document.addEventListener("DOMContentLoaded", setupCarousel);
  // Handle view transitions / Astro SPA navigation
  document.addEventListener("astro:page-load", setupCarousel);
</script>
